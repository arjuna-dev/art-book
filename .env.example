# Copy this file to .env and fill in the providers you want to use.
# The script loads .env from this directory by default.

OPENAI_API_KEY=

# Gemini uses Vertex AI. Authenticate with Google ADC/gcloud, then set the project.
VERTEX_PROJECT=
VERTEX_LOCATION=global

MAI_API_KEY=
MAI_ENDPOINT=
MAI_MODEL=MAI-Image-2
# AZURE_OPENAI_API_KEY= can be used instead of MAI_API_KEY.
